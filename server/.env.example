# Copy this file to `.env` and adjust as needed. Never commit the real `.env`.

PORT=4000
CORS_ORIGIN=http://localhost:5173
PRODUCTION_FRONTEND_URL=https://your-production-frontend.example

# Database configuration
# DATABASE_BACKEND: 'sqlite' (default) or 'postgres'
# For SQLite: Only DB_FILE is needed
# For PostgreSQL: Only DATABASE_URL is needed
# Phase 2: media_assets uses PostgreSQL if DATABASE_BACKEND=postgres, all other tables remain SQLite
DATABASE_BACKEND=sqlite
DATABASE_URL=postgresql://username:password@host:port/database
DB_FILE=server/data/bharti.sqlite

# Admin credentials (used only to seed the `admins` table on first boot; the
# password is hashed with bcrypt before it is stored — it is never kept as
# plaintext in the database).
ADMIN_USERNAME=replace-with-admin-username
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Used to sign/verify session JWTs. Change this to a long random string in
# any real deployment.
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Cloudinary configuration for cloud storage (optional)
# Leave blank to use local filesystem storage
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
