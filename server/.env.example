# Copy this file to `.env` and adjust as needed. Never commit the real `.env`.

PORT=4000
CORS_ORIGIN=

# Admin credentials (used only to seed the `admins` table on first boot; the
# password is hashed with bcrypt before it is stored — it is never kept as
# plaintext in the database).
ADMIN_USERNAME=Shashank@11
ADMIN_PASSWORD=Shashank@2026

# Used to sign/verify session JWTs. Change this to a long random string in
# any real deployment.
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
